{
  "name": "@hipaalint/ai",
  "version": "1.0.0",
  "description": "Helps identify potential HIPAA compliance issues — PHI detection, compliance scoring, and audit reports for Claude Code, Cursor, and AI coding agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hipaalint": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    },
    "./engine": {
      "import": "./dist/engine/index.js",
      "types": "./dist/engine/index.d.ts"
    },
    "./mcp-server": {
      "import": "./dist/mcp-server/index.js"
    }
  },
  "files": [
    "dist/",
    "src/rules/db/*.sql",
    "skills/",
    "agents/",
    ".claude-plugin/",
    ".mcp.json",
    "assets/logo.svg",
    "assets/logo-dark.svg",
    "AGENTS.md",
    "NOTICE",
    "action/action.yml",
    "hooks/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "node scripts/copy-assets.mjs",
    "scripts:check": "node --check scripts/copy-assets.mjs && node --check scripts/generate-framework-seeds.mjs && node --check scripts/sync-vscode-engine.mjs && node --check scripts/package-vscode.mjs && bash -n scripts/run-jetbrains-build.sh",
    "rules:generate": "node scripts/generate-framework-seeds.mjs",
    "vscode:sync-engine": "node scripts/sync-vscode-engine.mjs",
    "dev": "tsx watch src/mcp-server/index.ts",
    "start": "node dist/mcp-server/index.js",
    "cli": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest run --config vitest.benchmark.config.ts",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'vscode-extension/src/**/*.ts' --max-warnings 0",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' 'vscode-extension/src/**/*.ts' --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' 'vscode-extension/src/**/*.ts' 'scripts/*.mjs' '*.json' '.github/workflows/*.yml' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' 'vscode-extension/src/**/*.ts' 'scripts/*.mjs' '*.json' '.github/workflows/*.yml' '*.md'",
    "typecheck": "tsc --noEmit && npm --prefix vscode-extension run typecheck",
    "package:dry-run": "npm pack --dry-run",
    "vscode:compile": "npm run build && npm run vscode:sync-engine && npm --prefix vscode-extension run compile",
    "vscode:package": "npm run vscode:compile && node scripts/package-vscode.mjs",
    "jetbrains:build": "bash scripts/run-jetbrains-build.sh",
    "release:prepare": "node scripts/prepare-release.mjs",
    "verify:release": "npm run scripts:check && npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run rules:generate && npm run package:dry-run && npm run vscode:package && npm run jetbrains:build && bash scripts/validate-plugin.sh",
    "prepublishOnly": "npm run build && npm run test",
    "db:init": "tsx src/rules/init-db.ts",
    "db:seed": "tsx src/rules/seed-db.ts",
    "plugin:validate": "bash scripts/validate-plugin.sh",
    "plugin:publish": "bash scripts/publish-plugin.sh"
  },
  "keywords": [
    "hipaa",
    "hipaa-compliance",
    "claude-code-plugin",
    "healthcare-compliance",
    "hipaa-security-rule",
    "mcp-server"
  ],
  "author": "Shiv Yadav",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/shivyadavus/hipaalint.git"
  },
  "homepage": "https://github.com/shivyadavus/hipaalint#readme",
  "bugs": {
    "url": "https://github.com/shivyadavus/hipaalint/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^11.0.0",
    "pdfkit": "^0.15.0",
    "typescript": "^5.9.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.6.2",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
